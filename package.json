{
  "name": "novamnesis-laboratories",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "test:visual:update-browsers": "playwright install chromium",
    "rag": "node scripts/generate-rag-data.mjs",
    "rag:tidb:dry-run": "node scripts/tidb-import-rag-data.mjs --dry-run",
    "rag:tidb:import": "node scripts/tidb-import-rag-data.mjs",
    "rag:tidb:import-local-vector": "node scripts/tidb-import-rag-data.mjs --local-embeddings",
    "rag:tidb:fulltext-index": "node scripts/tidb-import-rag-data.mjs --schema-only --apply-fulltext-index",
    "rag:benchmark": "node scripts/benchmark-rag-chat.mjs",
    "taxonomy:tech": "node scripts/update-tech-taxonomy.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "mysql2": "^3.22.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
