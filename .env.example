GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: only needed later if you want vector embeddings.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=1536

# Use either TIDB_DATABASE_URL or the separate TiDB fields below.
TIDB_DATABASE_URL=
TIDB_HOST=
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=
TIDB_SSL=true
TIDB_SSL_REJECT_UNAUTHORIZED=true
TIDB_RAG_SEARCH_MODE=keyword
